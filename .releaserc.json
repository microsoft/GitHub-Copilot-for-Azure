{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "plugin/CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec", 
      {
        "prepareCmd": "cd scripts && node --import tsx src/update-plugin-version.ts ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["plugin/.claude-plugin/plugin.json", "plugin/.cursor-plugin/plugin.json", "plugin/.plugin/plugin.json", "plugin/CHANGELOG.md"],
        "message": "chore: update plugin versions to ${nextRelease.version} [skip ci]"
      }
    ]
  ]
}