{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec", 
      {
        "prepareCmd": "node --import tsx scripts/src/update-plugin-version.ts ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["plugin/.claude-plugin/plugin.json", "plugin/.plugin/plugin.json"],
        "message": "chore: update plugin versions to ${nextRelease.version} [skip ci]"
      }
    ]
  ]
}